# SMTP Configuration
# For Gmail: use an App Password (myaccount.google.com/apppasswords), not your account password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=info@connectfirst.today
SMTP_PASSWORD=your_app_password_here

# Sender Identity
FROM_NAME=Logan / ConnectFirst
FROM_EMAIL=info@connectfirst.today

# Email Settings
EMAIL_SUBJECT=missed a call?

# Paths (relative to repo root)
PROSPECTS_FILE=data/prospects_example.csv
EMAIL_TEMPLATE=templates/cold_email.txt
LOG_DIR=logs/

# Safety
# Set to true to log what would be sent without actually sending anything
DRY_RUN=false
# Hard cap per run — keeps volume low for cold outreach reputation
DAILY_SEND_LIMIT=20
